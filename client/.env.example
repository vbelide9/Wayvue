VITE_OPENWEATHER_API_KEY=
VITE_TOMTOM_API_KEY=
VITE_API_URL=http://localhost:3001/api

# Supabase — powers community features (ratings, and later group trips / social feed).
# From Supabase Dashboard → Project Settings → API. The anon key is safe to expose in
# the browser (Row-Level Security protects the data). Leave blank to disable these
# features locally — the app runs fine without them.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Booking affiliate IDs for the hotel & rental "Book" buttons (optional — links work either
# way; they only earn commission once set).
#   Booking.com: your affiliate/partner "aid" (partner.booking.com or via Travelpayouts).
VITE_BOOKING_AFFILIATE_ID=
#   Expedia Group (Expedia / Vrbo): publisher ID from your network (Impact / Partnerize).
#   Note: you must also implement the network deep-link wrap in lib/bookingPartners.ts.
VITE_EXPEDIA_AFFILIATE_ID=

# Amazon Associates tag for the "Pack for this trip" affiliate links (e.g. wayvue-20).
# Sign up at affiliate-program.amazon.com. Leave blank and the links still work (they just
# open Amazon search without earning commission).
VITE_AMAZON_ASSOCIATE_TAG=
