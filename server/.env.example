# Wayvue API Configuration
# Copy this file to .env and fill in your keys
# See API_DOCUMENTATION.md for full details on each API

PORT=3001

# ---- Required API Keys ----

# U.S. Energy Information Administration — real gas prices by PADD region
# Register free (no credit card): https://www.eia.gov/opendata/
EIA_API_KEY=

# TomTom Traffic Flow API — real-time traffic speed and congestion data
# Register free (no credit card): https://developer.tomtom.com/
# Free tier: 2,500 requests/day
TOMTOM_API_KEY=

# ---- Optional API Keys ----

# TollGuru — real toll pricing from the route polyline
# Register free tier: https://tollguru.com/
# If unset, Wayvue falls back to a state-based toll heuristic (flagged "estimated").
TOLLGURU_API_KEY=

# Amadeus — LIVE hotel pricing (Hotel Search API)
# Free self-service account: https://developers.amadeus.com/
# If unset, hotels show as suggestions with real booking links but NO prices
# (Wayvue never shows fabricated hotel rates).
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
# 'test' (default, sample data) or 'production' (live data, requires app promotion)
AMADEUS_ENV=test

# Mapbox (not currently used — OSRM is used for routing)
MAPBOX_ACCESS_TOKEN=

# OpenWeather (not currently used — Open-Meteo is used for weather)
OPENWEATHER_API_KEY=

# 511NY DOT — traffic camera feeds (NY State only)
# Register at: https://511ny.org/
NY_511_API_KEY=

# Supabase — server-side route recommendation cache (keeps the same route's places
# stable across searches). SUPABASE_URL is your project URL; the SERVICE ROLE key is
# under Project Settings → API → "service_role" (secret — NEVER expose in the client).
# Leave blank to disable caching (app falls back to live fetching).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Viator (TripAdvisor) — activities / things-to-do near the destination (affiliate).
# Request "Basic / Affiliate" access at the Viator Partner Program. Leave blank to keep
# the Activities section in its "coming soon" placeholder state.
VIATOR_API_KEY=
